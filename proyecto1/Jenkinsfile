pipeline {
    agent any
    
    tools {
        nodejs 'NodeJS'
    }
    
    environment {
        REGISTRY = 'ghcr.io'
        IMAGE_NAME = 'ALalejandra/proyecto1'
    }
    
    stages {
        stage('Prepare') {
            steps {
                echo '⚙️ Validando comandos disponibles...'
                sh 'node --version'
                sh 'npm --version'
            }
        }
        
        stage('Install Dependencies') {
            steps {
                echo '📥 Instalando dependencias de la app...'
                // Cambiamos 'npm ci' por 'npm install'
                sh 'npm install'
            }
        }
        
        stage('Test') {
            steps {
                echo '🧪 Ejecutando pruebas del proyecto...'
                sh 'npm test'
            }
        }
    }
    
    post {
        success {
            echo '🎉 ¡Felicidades! El pipeline se ejecutó y completó con éxito.'
        }
        failure {
            echo '❌ El pipeline tuvo un fallo, revisa los logs de arriba.'
        }
    }
}