pipeline {
    // Le decimos a Jenkins que use un contenedor de Node para correr las pruebas e instalar dependencias
    agent {
        docker { 
            image 'node:18-alpine' 
        }
    }
    
    environment {
        REGISTRY = 'ghcr.io'
        IMAGE_NAME = 'ALalejandra/proyecto1'
    }
    
    stages {
        stage('Prepare') {
            steps {
                echo '⚙️ Preparando entorno dentro del contenedor...'
                sh 'node --version'
                sh 'npm --version'
            }
        }
        
        stage('Install Dependencies') {
            steps {
                echo '📥 Instalando dependencias...'
                sh 'npm ci'
            }
        }
        
        stage('Test') {
            steps {
                echo '🧪 Ejecutando tests...'
                sh 'npm test'
            }
        }
        
        // Dejamos las etapas de empaquetado listas para cuando configures Docker en Jenkins
        stage('Build Docker Image') {
            steps {
                echo '🐳 Saltando construcción de imagen en entorno local...'
            }
        }
    }
    
    post {
        success {
            echo '🎉 Pipeline completado exitosamente!'
        }
        failure {
            echo '❌ Pipeline falló!'
        }
    }
}